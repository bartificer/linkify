{
    "opts": {
        "encoding": "utf8",
        "pedantic": true,
        "readme": "./README.md",
        "template": "./node_modules/clean-jsdoc-theme",
        "theme_opts": {
            "default_theme": "fallback-light",
            "homepageTitle": "Linkifier from Bartificer Creations",
            "title": "Bartificer Linkifier",
            "includeFilesListInHomepage": true,
            "sections": ["Modules", "Classes", "Externals"]
        }
    },
    "source": {
        "include": ["./src/"],
        "includePattern": ".+\\.(js|mjs|jsdoc)$"
    }, 
    "plugins": [
        "plugins/markdown"
    ],
    "markdown": {
        "hardwrap": false,
        "idInHeadings": true
    },
    "tags": {
        "allowUnknownTags": false,
        "dictionaries": ["jsdoc","closure"]
    }
}