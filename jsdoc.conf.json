{
    "sourceType": "module",
    "opts": {
        "encoding": "utf8",
        "pedantic": true,
        "readme": "./README.md",
        "template": "./node_modules/docdash",
        "destination": "docs/",
        "recurse": true,
        "verbose": true
    },
    "source": {
        "include": [
            "./src/",
            "./bin/"
        ],
        "includePattern": ".+\\.(js|mjs|jsdoc)$"
    }, 
    "plugins": [
        "plugins/markdown"
    ],
    "markdown": {
        "hardwrap": false,
        "idInHeadings": true,
        "parser": "marked"
    },
    "tags": {
        "allowUnknownTags": false,
        "dictionaries": ["jsdoc","closure"]
    },
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false,
        "default": {
            "staticFiles": {
                "include": ["./docs-static"]
            }
        }
    },
    "docdash": {
        "static": true,
        "sort": true,
        "sectionOrder": ["Classes", "Global", "Externals", "Modules"],
        "openGraph": {
            "title": "@bartificer/linkify",
            "type": "website",
            "image": "",
            "site_name": "@bartificer/linkify Documentation",
            "url": "https://bartificer.github.io/linkify/"
        },
        "meta": {
            "title": "@bartificer/linkify Documentation",
            "description": "Documentation for the @bartificer/linkify package",
            "keyword": "documentation, linkify, link, template, javascript, generator, npm, module, package"
        },
        "search": true,
        "collapse": false,
        "wrap": true,
        "typedefs": true,
        "navLevel": 1,
        "private": true,
        "removeQuotes": "trim",
        "scripts": [
            "./docdash-overrides.css",
            "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css",
            "https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js",
            "./mermaid-init.js"
        ],
        "menu": {
            "On GitHub": {
                "href":"https://github.com/bartificer/linkify",
                "target": "_blank"
            },
            "Bartificer Creations": {
                "href":"https://bartificer.net/",
                "target": "_blank"
            }
        },
        "scopeInOutputPath": true,
        "nameInOutputPath": true,
        "versionInOutputPath": true
    }
}