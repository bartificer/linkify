{
    "sourceType": "module",
    "opts": {
        "encoding": "utf8",
        "pedantic": true,
        "readme": "./README.md",
        "template": "./node_modules/docdash"
    },
    "source": {
        "include": ["./src/"],
        "includePattern": ".+\\.(js|mjs|jsdoc)$"
    }, 
    "plugins": [
        "plugins/markdown"
    ],
    "markdown": {
        "hardwrap": false,
        "idInHeadings": true
    },
    "tags": {
        "allowUnknownTags": false,
        "dictionaries": ["jsdoc","closure"]
    },
    "docdash": {
        "collapse": true,
        "menu": {
            "On GitHub": {
                "href":"https://github.com/bartificer/linkify",
                "target": "_blank"
            },
            "Bartificer Creations": {
                "href":"https://bartificer.net/",
                "target": "_blank"
            }
        },
        "search": true,
        "sectionOrder": ["Modules", "Classes", "Externals"],
        "static": true,
        "typedefs": true
    }
}